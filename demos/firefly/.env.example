# Bramble Ski — AI Holiday Adviser Demo
# Copy this file to .env and fill in your values for local development.
# Never commit .env to version control.

# Anthropic API key — used by api/chat.js (chat proxy) and api/send-email.js (profile extraction)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Resend API key — used by api/send-email.js to send summary emails
# Get yours at: https://resend.com/
# Note: sending domain must be verified in Resend to deliver to arbitrary email addresses.
# TODO: Resend sending domain — onboarding@resend.dev for testing only; update once brambleski.com domain is verified
RESEND_API_KEY=re_...
