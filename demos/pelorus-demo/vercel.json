{
  "version": 2,
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/send-email", "destination": "/api/send-email.js" },
    { "source": "/demo", "destination": "/chat.html" },
    { "source": "/", "destination": "/pitch-deck.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    }
  ]
}
